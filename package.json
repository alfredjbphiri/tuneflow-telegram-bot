{
  "name": "tuneflow-telegram-bot",
  "version": "0.1.0",
  "description": "A Telegram bot that lets users search and download songs as MP3s from YouTube. Minimal: just /search + /get. Built for Render free tier.",
  "main": "src/bot.js",
  "scripts": {
    "start": "node src/bot.js",
    "dev": "nodemon src/bot.js",
    "test": "jest --runInBand"
  },
  "keywords": ["telegram", "bot", "music", "youtube", "mp3", "download"],
  "author": "alfredphiri",
  "license": "MIT",
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.10",
    "dotenv": "^16.4.5",
    "fluent-ffmpeg": "^2.1.3",
    "node-telegram-bot-api": "^0.66.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4"
  }
}
