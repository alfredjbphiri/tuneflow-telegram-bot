# Telegram bot token from @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz

# Optional: comma-separated list of Telegram user IDs allowed to use the bot.
# Empty = allow everyone.
ALLOWED_USERS=

# Optional: max downloads per user per hour. 0 = unlimited.
MAX_PER_HOUR=10

# Optional: max results per /search reply.
SEARCH_LIMIT=5

# Optional: max audio file size we'll send to Telegram in bytes.
# Telegram Bot API limit is 50 MB; stay safely under.
MAX_FILE_BYTES=47185920

# Optional: max track duration in seconds. Skip long mixes.
MAX_DURATION_SEC=600

# Optional: use polling (true) or webhook (false). Polling is simpler for Render free.
POLLING=true

# Render injects PORT automatically. Don't change this.
PORT=3000
